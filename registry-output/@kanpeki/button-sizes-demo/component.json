      "content": "import { ArrowUpRightIcon } from \"lucide-react\";\n\nimport { Button } from \"~/registry/ui/button/button\";\n\nexport function ButtonSizesDemo() {\n  return (\n    <div className=\"flex flex-col items-start gap-8 sm:flex-row\">\n      <Button className=\"sr-only focus:not-sr-only\">Skip to content</Button>\n      <div className=\"flex items-start gap-2\">\n        <Button size=\"sm\" variant=\"outline\">\n          Small\n        </Button>\n        <Button aria-label=\"Submit\" size=\"icon-sm\" variant=\"outline\">\n          <ArrowUpRightIcon />\n        </Button>\n      </div>\n      <div className=\"flex items-start gap-2\">\n        <Button variant=\"outline\">Default</Button>\n        <Button aria-label=\"Submit\" size=\"icon\" variant=\"outline\">\n          <ArrowUpRightIcon />\n        </Button>\n      </div>\n      <div className=\"flex items-start gap-2\">\n        <Button size=\"lg\" variant=\"outline\">\n          Large\n        </Button>\n        <Button aria-label=\"Submit\" size=\"icon-lg\" variant=\"outline\">\n          <ArrowUpRightIcon />\n        </Button>\n      </div>\n    </div>\n  );\n}\n",
      "path": "src/registry/examples/button/button-sizes-demo.tsx",
      "type": "registry:example"
    }
  ],
  "name": "button-sizes-demo",
  "registryDependencies": ["@kanpeki/button", "lucide-react"],
  "type": "registry:example"
}
