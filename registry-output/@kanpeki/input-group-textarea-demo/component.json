{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "files": [
    {
      "content": "import { CopyIcon, CornerDownLeftIcon, RefreshCwIcon } from \"lucide-react\";\nimport { Icons } from \"~/components/icons\";\nimport { InputGroup } from \"~/registry/ui/input-group\";\n\nexport function InputGroupTextareaExample() {\n  return (\n    <div className=\"grid w-full max-w-md gap-4\">\n      <InputGroup.Root>\n        <InputGroup.Textarea\n          className=\"min-h-50\"\n          id=\"textarea-code-32\"\n          placeholder=\"console.log('Hello, world!');\"\n        />\n        <InputGroup.Addon align=\"block-end\" className=\"border-t\">\n          <InputGroup.Text>Line 1, Column 1</InputGroup.Text>\n          <InputGroup.Button className=\"ml-auto\" size=\"sm\" variant=\"default\">\n            Run <CornerDownLeftIcon />\n          </InputGroup.Button>\n        </InputGroup.Addon>\n        <InputGroup.Addon align=\"block-start\" className=\"border-b\">\n          <InputGroup.Text className=\"font-medium font-mono\">\n            <Icons.JavaScript />\n            script.js\n          </InputGroup.Text>\n          <InputGroup.Button className=\"ml-auto\" size=\"icon-xs\">\n            <RefreshCwIcon />\n          </InputGroup.Button>\n          <InputGroup.Button size=\"icon-xs\" variant=\"ghost\">\n            <CopyIcon />\n          </InputGroup.Button>\n        </InputGroup.Addon>\n      </InputGroup.Root>\n    </div>\n  );\n}\n",
      "path": "src/registry/examples/input-group/input-group-textarea-demo.tsx",
      "type": "registry:example"
    }
  ],
  "name": "input-group-textarea-demo",
  "registryDependencies": ["@kanpeki/input-group"],
  "type": "registry:example"
}
