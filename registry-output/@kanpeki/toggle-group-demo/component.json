{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "files": [
    {
      "content": "import { BoldIcon, ItalicIcon, UnderlineIcon } from \"lucide-react\";\n\nimport { ToggleGroup } from \"~/registry/ui/toggle-group\";\n\nexport function ToggleGroupDemo() {\n  return (\n    <div className=\"flex flex-wrap items-start gap-4\">\n      <ToggleGroup.Root selectionMode=\"multiple\">\n        <ToggleGroup.Item aria-label=\"Toggle bold\" id=\"bold\">\n          <BoldIcon />\n        </ToggleGroup.Item>\n        <ToggleGroup.Item aria-label=\"Toggle italic\" id=\"italic\">\n          <ItalicIcon />\n        </ToggleGroup.Item>\n        <ToggleGroup.Item aria-label=\"Toggle strikethrough\" id=\"strikethrough\">\n          <UnderlineIcon />\n        </ToggleGroup.Item>\n      </ToggleGroup.Root>\n\n      <ToggleGroup.Root\n        className=\"*:data-[slot=toggle-group-item]:w-20\"\n        defaultSelectedKeys={[\"all\"]}\n        selectionMode=\"single\"\n        variant=\"outline\"\n      >\n        <ToggleGroup.Item aria-label=\"Toggle all\" id=\"all\">\n          All\n        </ToggleGroup.Item>\n        <ToggleGroup.Item aria-label=\"Toggle missed\" id=\"missed\">\n          Missed\n        </ToggleGroup.Item>\n      </ToggleGroup.Root>\n\n      <ToggleGroup.Root\n        className=\"*:data-[slot=toggle-group-item]:px-3\"\n        defaultSelectedKeys={[\"last-24-hours\"]}\n        selectionMode=\"single\"\n        size=\"sm\"\n        variant=\"outline\"\n      >\n        <ToggleGroup.Item aria-label=\"Toggle last 24 hours\" id=\"last-24-hours\">\n          Last 24 hours\n        </ToggleGroup.Item>\n        <ToggleGroup.Item aria-label=\"Toggle last 7 days\" id=\"last-7-days\">\n          Last 7 days\n        </ToggleGroup.Item>\n      </ToggleGroup.Root>\n\n      <ToggleGroup.Root\n        className=\"*:data-[slot=toggle-group-item]:px-3\"\n        defaultSelectedKeys={[\"last-24-hours\"]}\n        selectionMode=\"single\"\n        size=\"sm\"\n      >\n        <ToggleGroup.Item aria-label=\"Toggle last 24 hours\" id=\"last-24-hours\">\n          Last 24 hours\n        </ToggleGroup.Item>\n        <ToggleGroup.Item aria-label=\"Toggle last 7 days\" id=\"last-7-days\">\n          Last 7 days\n        </ToggleGroup.Item>\n      </ToggleGroup.Root>\n    </div>\n  );\n}\n",
      "path": "src/registry/examples/toggle/toggle-group-demo.tsx",
      "type": "registry:example"
    }
  ],
  "name": "toggle-group-demo",
  "registryDependencies": ["@kanpeki/toggle"],
  "type": "registry:example"
}
