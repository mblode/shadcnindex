{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "files": [
    {
      "content": "import { LoaderIcon } from \"lucide-react\";\nimport { InputGroup } from \"~/registry/ui/input-group\";\nimport { Spinner } from \"~/registry/ui/spinner\";\n\nexport function InputGroupSpinner() {\n  return (\n    <div className=\"grid w-full max-w-sm gap-4\">\n      <InputGroup.Root data-disabled>\n        <InputGroup.Input disabled placeholder=\"Searching...\" />\n        <InputGroup.Addon align=\"inline-end\">\n          <Spinner />\n        </InputGroup.Addon>\n      </InputGroup.Root>\n      <InputGroup.Root data-disabled>\n        <InputGroup.Input disabled placeholder=\"Processing...\" />\n        <InputGroup.Addon>\n          <Spinner />\n        </InputGroup.Addon>\n      </InputGroup.Root>\n      <InputGroup.Root data-disabled>\n        <InputGroup.Input disabled placeholder=\"Saving changes...\" />\n        <InputGroup.Addon align=\"inline-end\">\n          <InputGroup.Text>Saving...</InputGroup.Text>\n          <Spinner />\n        </InputGroup.Addon>\n      </InputGroup.Root>\n      <InputGroup.Root data-disabled>\n        <InputGroup.Input disabled placeholder=\"Refreshing data...\" />\n        <InputGroup.Addon>\n          <LoaderIcon className=\"animate-spin\" />\n        </InputGroup.Addon>\n        <InputGroup.Addon align=\"inline-end\">\n          <InputGroup.Text className=\"text-muted-foreground\">\n            Please wait...\n          </InputGroup.Text>\n        </InputGroup.Addon>\n      </InputGroup.Root>\n    </div>\n  );\n}\n",
      "path": "src/registry/examples/input-group/input-group-spinner-demo.tsx",
      "type": "registry:example"
    }
  ],
  "name": "input-group-spinner-demo",
  "registryDependencies": ["@kanpeki/input-group", "@kanpeki/spinner"],
  "type": "registry:example"
}
