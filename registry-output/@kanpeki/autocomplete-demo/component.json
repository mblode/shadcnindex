{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "files": [
    {
      "content": "\"use client\";\n\nimport {\n  CalculatorIcon,\n  CalendarIcon,\n  CreditCardIcon,\n  SearchIcon,\n  SettingsIcon,\n  SmileIcon,\n  UserIcon,\n} from \"lucide-react\";\nimport { Autocomplete } from \"~/registry/ui/autocomplete\";\nimport { Card } from \"~/registry/ui/card\";\nimport { InputGroup } from \"~/registry/ui/input-group\";\nimport { Keyboard } from \"~/registry/ui/keyboard\";\nimport { Menu } from \"~/registry/ui/menu\";\nimport { SearchField } from \"~/registry/ui/search-field\";\n\nexport function AutocompleteDemo() {\n  return (\n    <Card.Root className=\"w-full\">\n      <Autocomplete>\n        <Card.Header>\n          <InputGroup.Root\n            render={<SearchField.Root aria-label=\"Search\" className=\"px-0\" />}\n          >\n            <InputGroup.Addon>\n              <SearchIcon />\n            </InputGroup.Addon>\n            <InputGroup.Input placeholder=\"Type a command or search...\" />\n            <InputGroup.Addon align=\"inline-end\">\n              <SearchField.Button />\n            </InputGroup.Addon>\n          </InputGroup.Root>\n        </Card.Header>\n\n        <Card.Content>\n          <Menu.Content\n            renderEmptyState={() => <Menu.Empty>No results found.</Menu.Empty>}\n          >\n            <Menu.Group>\n              <Menu.Label>Suggestions</Menu.Label>\n\n              <Menu.Item textValue=\"Calendar\">\n                <CalendarIcon />\n                <span>Calendar</span>\n              </Menu.Item>\n              <Menu.Item textValue=\"Search Emoji\">\n                <SmileIcon />\n                <span>Search Emoji</span>\n              </Menu.Item>\n              <Menu.Item textValue=\"Calculator\">\n                <CalculatorIcon />\n                <span>Calculator</span>\n              </Menu.Item>\n            </Menu.Group>\n            <Menu.Separator />\n            <Menu.Group>\n              <Menu.Label>Settings</Menu.Label>\n\n              <Menu.Item textValue=\"Profile\">\n                <UserIcon />\n                <span>Profile</span>\n                <Keyboard variant=\"menu\">⌘P</Keyboard>\n              </Menu.Item>\n              <Menu.Item textValue=\"Billing\">\n                <CreditCardIcon />\n                <span>Billing</span>\n                <Keyboard variant=\"menu\">⌘B</Keyboard>\n              </Menu.Item>\n              <Menu.Item textValue=\"Settings\">\n                <SettingsIcon />\n                <span>Settings</span>\n                <Keyboard variant=\"menu\">⌘S</Keyboard>\n              </Menu.Item>\n            </Menu.Group>\n          </Menu.Content>\n        </Card.Content>\n      </Autocomplete>\n    </Card.Root>\n  );\n}\n",
      "path": "src/registry/examples/autocomplete/autocomplete-demo.tsx",
      "type": "registry:example"
    }
  ],
  "name": "autocomplete-demo",
  "registryDependencies": [
    "@kanpeki/autocomplete",
    "@kanpeki/dialog",
    "@kanpeki/keyboard",
    "@kanpeki/menu",
    "@kanpeki/search-field"
  ],
  "type": "registry:example"
}
