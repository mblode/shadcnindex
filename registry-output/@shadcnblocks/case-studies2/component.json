{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "case-studies2",
  "title": "Case-studies",
  "description": "This component displays case studies highlighting user testimonials and key performance metrics such as satisfaction rates and ROI improvement. It features visual and text elements including user quotes, images, and company logos to illustrate the impact and effectiveness of a product or service.",
  "dependencies": ["clsx", "tailwind-merge", "@radix-ui/react-separator"],
