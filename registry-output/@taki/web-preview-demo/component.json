{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "web-preview-demo",
  "registryDependencies": [
    "https://taki-ui.com/r/web-preview.json",
    "https://taki-ui.com/r/button.json",
    "https://taki-ui.com/r/disclosure.json",
    "https://taki-ui.com/r/input.json",
    "https://taki-ui.com/r/tooltip.json",
    "https://taki-ui.com/r/badge.json"
  ],
  "files": [
    {
      "path": "registry/new-york/examples/web-preview-demo.tsx",
      "content": "\"use client\"\n\nimport { useState } from \"react\"\nimport { ChevronLeftIcon, ChevronRightIcon, RotateCwIcon } from \"lucide-react\"\n\nimport {\n  WebPreview,\n  WebPreviewBody,\n  WebPreviewConsole,\n  WebPreviewNavigation,\n  WebPreviewNavigationButton,\n  WebPreviewUrl,\n} from \"@/registry/new-york/ai-elements/web-preview\"\n\nexport default function WebPreviewDemo() {\n  const [url, setUrl] = useState(\"https://ai-sdk.dev\")\n  const [logs] = useState([\n    {\n      level: \"log\" as const,\n      message: \"Page loaded successfully\",\n      timestamp: new Date(),\n    },\n    {\n      level: \"log\" as const,\n      message: \"Ready to display content\",\n      timestamp: new Date(),\n    },\n  ])\n\n  return (\n    <div className=\"h-[600px] w-full\">\n      <WebPreview defaultUrl={url} onUrlChange={setUrl}>\n        <WebPreviewNavigation>\n          <WebPreviewNavigationButton disabled tooltip=\"Back\">\n            <ChevronLeftIcon className=\"size-4\" />\n          </WebPreviewNavigationButton>\n          <WebPreviewNavigationButton disabled tooltip=\"Forward\">\n            <ChevronRightIcon className=\"size-4\" />\n          </WebPreviewNavigationButton>\n          <WebPreviewNavigationButton tooltip=\"Refresh\">\n            <RotateCwIcon className=\"size-4\" />\n          </WebPreviewNavigationButton>\n          <WebPreviewUrl placeholder=\"Enter URL...\" />\n        </WebPreviewNavigation>\n\n        <WebPreviewBody src={url} />\n\n        <WebPreviewConsole logs={logs} />\n      </WebPreview>\n    </div>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}
