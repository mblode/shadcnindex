{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "extends": "none",
  "name": "navbar-03",
  "title": "navbar-03",
  "description": "navbar-03",
  "registryDependencies": [
    "https://intentui.com/r/heading",
    "https://intentui.com/r/avatar",
    "https://intentui.com/r/button",
    "https://intentui.com/r/link",
    "https://intentui.com/r/menu",
    "https://intentui.com/r/navbar",
    "https://intentui.com/r/separator"
  ],
  "files": [
    {
      "path": "registry/blocks/navbar-03/page.tsx",
      "content": "import { Heading } from \"@/components/ui/heading\"\n\nexport default function Page() {\n  return <Heading>Inset navbar</Heading>\n}\n",
      "type": "registry:page",
      "target": "app/navbar-03/page.tsx"
    },
    {
      "path": "registry/blocks/navbar-03/app-navbar.tsx",
      "content": "\"use client\"\nimport { ChevronDownIcon, MagnifyingGlassIcon, ShoppingBagIcon } from \"@heroicons/react/24/outline\"\nimport { Avatar } from \"@/components/ui/avatar\"\nimport { Button } from \"@/components/ui/button\"\nimport { Link } from \"@/components/ui/link\"\nimport { Menu, MenuContent, MenuItem } from \"@/components/ui/menu\"\nimport {\n  Navbar,\n  NavbarGap,\n  NavbarItem,\n  NavbarMobile,\n  type NavbarProps,\n  NavbarProvider,\n  NavbarSection,\n  NavbarSeparator,\n  NavbarSpacer,\n  NavbarStart,\n  NavbarTrigger,\n} from \"@/components/ui/navbar\"\nimport { Separator } from \"@/components/ui/separator\"\nimport { UserMenu } from \"@/registry/blocks/navbar-03/user-menu\"\n\nconst categories = [\n  { id: 1, label: \"Electronics\", url: \"#\" },\n  { id: 2, label: \"Fashion\", url: \"#\" },\n  { id: 3, label: \"Home & Kitchen\", url: \"#\" },\n  { id: 4, label: \"Sports\", url: \"#\" },\n  { id: 5, label: \"Books\", url: \"#\" },\n  { id: 6, label: \"Beauty & Personal Care\", url: \"#\" },\n  { id: 7, label: \"Grocery\", url: \"#\" },\n  { id: 8, label: \"Toys & Games\", url: \"#\" },\n  { id: 9, label: \"Automotive\", url: \"#\" },\n  { id: 10, label: \"Health & Wellness\", url: \"#\" },\n]\n\nexport default function AppNavbar(props: NavbarProps) {\n  return (\n    <NavbarProvider>\n      <Navbar {...props}>\n        <NavbarStart>\n          <Link\n            className=\"flex items-center gap-x-2 font-medium\"\n            aria-label=\"Goto documentation of Navbar\"\n            href=\"/docs/components/layouts/navbar\"\n          >\n            <Avatar\n              isSquare\n              size=\"sm\"\n              className=\"outline-hidden\"\n              src=\"https://design.intentui.com/logo?color=155DFC\"\n            />\n            <span>\n              Intent <span className=\"text-muted-fg\">UI</span>\n            </span>\n          </Link>\n        </NavbarStart>\n        <NavbarGap />\n        <NavbarSection>\n          <NavbarItem href=\"#\" isCurrent>\n            Home\n          </NavbarItem>\n          <NavbarItem href=\"#\">Shop</NavbarItem>\n          <NavbarItem href=\"#\">Offers</NavbarItem>\n          <NavbarItem href=\"#\">Orders</NavbarItem>\n          <Menu>\n            <NavbarItem>\n              Categories\n              <ChevronDownIcon className=\"col-start-3\" />\n            </NavbarItem>\n            <MenuContent className=\"min-w-(--trigger-width) sm:min-w-56\" items={categories}>\n              {(item) => (\n                <MenuItem id={item.id} textValue={item.label} href={item.url}>\n                  {item.label}\n                </MenuItem>\n              )}\n            </MenuContent>\n          </Menu>\n        </NavbarSection>\n        <NavbarSpacer />\n        <NavbarSection className=\"max-md:hidden\">\n          <Button intent=\"plain\" size=\"sq-sm\" aria-label=\"Search for products\">\n            <MagnifyingGlassIcon />\n          </Button>\n          <Button intent=\"plain\" size=\"sq-sm\" aria-label=\"Your Bag\">\n            <ShoppingBagIcon />\n          </Button>\n          <Separator orientation=\"vertical\" className=\"mr-3 ml-1 h-5\" />\n          <UserMenu />\n        </NavbarSection>\n      </Navbar>\n      <NavbarMobile>\n        <NavbarTrigger />\n        <NavbarSpacer />\n        <Button intent=\"plain\" size=\"sq-sm\" aria-label=\"Search for products\">\n          <MagnifyingGlassIcon />\n        </Button>\n        <Button intent=\"plain\" size=\"sq-sm\" aria-label=\"Your Bag\">\n          <ShoppingBagIcon />\n        </Button>\n        <NavbarSeparator className=\"mr-2.5\" />\n        <UserMenu />\n      </NavbarMobile>\n    </NavbarProvider>\n  )\n}\n",
      "type": "registry:component"
    },
    {
      "path": "registry/blocks/navbar-03/user-menu.tsx",
      "content": "\"use client\"\n\nimport {\n  ArrowRightOnRectangleIcon,\n  Cog6ToothIcon,\n  CommandLineIcon,\n  LifebuoyIcon,\n  ShieldCheckIcon,\n  Squares2X2Icon,\n} from \"@heroicons/react/24/outline\"\nimport { Avatar } from \"@/components/ui/avatar\"\nimport {\n  Menu,\n  MenuContent,\n  MenuHeader,\n  MenuItem,\n  MenuSection,\n  MenuSeparator,\n  MenuTrigger,\n} from \"@/components/ui/menu\"\n\nexport function UserMenu() {\n  return (\n    <Menu>\n      <MenuTrigger aria-label=\"Open Menu\">\n        <Avatar\n          alt=\"cobain\"\n          size=\"md\"\n          isSquare\n          src=\"https://intentui.com/images/avatar/cobain.jpg\"\n        />\n      </MenuTrigger>\n      <MenuContent placement=\"bottom right\" className=\"min-w-60 sm:min-w-56\">\n        <MenuSection>\n          <MenuHeader separator>\n            <span className=\"block\">Kurt Cobain</span>\n            <span className=\"font-normal text-muted-fg\">@cobain</span>\n          </MenuHeader>\n        </MenuSection>\n\n        <MenuItem href=\"#dashboard\">\n          <Squares2X2Icon />\n          Dashboard\n        </MenuItem>\n        <MenuItem href=\"#settings\">\n          <Cog6ToothIcon />\n          Settings\n        </MenuItem>\n        <MenuItem href=\"#security\">\n          <ShieldCheckIcon />\n          Security\n        </MenuItem>\n        <MenuSeparator />\n        <MenuItem>\n          <CommandLineIcon />\n          Command Menu\n        </MenuItem>\n\n        <MenuItem href=\"#contact\">\n          <LifebuoyIcon />\n          Customer Support\n        </MenuItem>\n        <MenuSeparator />\n        <MenuItem href=\"#logout\">\n          <ArrowRightOnRectangleIcon />\n          Log out\n        </MenuItem>\n      </MenuContent>\n    </Menu>\n  )\n}\n",
      "type": "registry:component"
    }
  ],
  "type": "registry:block"
}
