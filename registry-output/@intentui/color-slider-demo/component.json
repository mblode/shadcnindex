{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "extends": "none",
  "name": "color-slider-demo",
  "title": "Color Slider",
  "description": "color-slider-demo",
  "registryDependencies": [
    "https://intentui.com/r/color-slider",
    "https://intentui.com/r/color-thumb",
    "https://intentui.com/r/field"
  ],
  "files": [
    {
      "path": "src/components/docs/colors/color-slider/color-slider-demo.tsx",
      "content": "\"use client\"\n\nimport { ColorSlider, ColorSliderOutput, ColorSliderTrack } from \"@/components/ui/color-slider\"\nimport { ColorThumb } from \"@/components/ui/color-thumb\"\nimport { Description } from \"@/components/ui/field\"\n\nexport default function ColorSliderDemo() {\n  return (\n    <ColorSlider channel=\"hue\" defaultValue=\"hsl(0, 100%, 50%)\">\n      <ColorSliderOutput />\n      <ColorSliderTrack>\n        <ColorThumb />\n      </ColorSliderTrack>\n      <Description>\n        This color slider is using the <strong className=\"font-medium text-fg\">hue</strong> channel.\n      </Description>\n    </ColorSlider>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/color-slider-demo/page.tsx"
    }
  ],
  "type": "registry:page"
}
