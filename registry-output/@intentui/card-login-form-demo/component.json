{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "extends": "none",
  "name": "card-login-form-demo",
  "title": "Card Login Form",
  "description": "card-login-form-demo",
  "dependencies": ["react-aria-components"],
  "registryDependencies": [
    "https://intentui.com/r/button",
    "https://intentui.com/r/card",
    "https://intentui.com/r/checkbox",
    "https://intentui.com/r/field",
    "https://intentui.com/r/input",
    "https://intentui.com/r/link",
    "https://intentui.com/r/text-field"
  ],
  "files": [
    {
      "path": "src/components/docs/surfaces/card/card-login-form-demo.tsx",
      "content": "\"use client\"\n\nimport { Form } from \"react-aria-components\"\nimport { Button } from \"@/components/ui/button\"\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from \"@/components/ui/card\"\nimport { Checkbox } from \"@/components/ui/checkbox\"\nimport { Label } from \"@/components/ui/field\"\nimport { Input } from \"@/components/ui/input\"\nimport { Link } from \"@/components/ui/link\"\nimport { TextField } from \"@/components/ui/text-field\"\n\nexport default function CardLoginFormDemo() {\n  return (\n    <Card className=\"mx-auto w-full max-w-md\">\n      <CardHeader>\n        <CardTitle>Login</CardTitle>\n        <CardDescription>Don't loose the level, just keep on going.</CardDescription>\n      </CardHeader>\n      <CardContent>\n        <Form className=\"space-y-6\">\n          <TextField isRequired>\n            <Label>Email</Label>\n            <Input placeholder=\"Enter your email\" />\n          </TextField>\n          <TextField isRequired>\n            <Label>Password</Label>\n            <Input type=\"password\" placeholder=\"Enter your password\" />\n          </TextField>\n          <div className=\"flex items-center justify-between\">\n            <Checkbox>Remember me</Checkbox>\n            <Link\n              className=\"text-base/6 text-primary-subtle-fg hover:underline sm:text-sm/6\"\n              href=\"#\"\n            >\n              Forgot password?\n            </Link>\n          </div>\n          <Button className=\"w-full\">Login</Button>\n        </Form>\n      </CardContent>\n    </Card>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/card-login-form-demo/page.tsx"
    }
  ],
  "type": "registry:page"
}
