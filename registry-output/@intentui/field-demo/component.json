{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "extends": "none",
  "name": "field-demo",
  "title": "Field",
  "description": "field-demo",
  "dependencies": ["react-aria-components"],
  "registryDependencies": [
    "https://intentui.com/r/button",
    "https://intentui.com/r/field",
    "https://intentui.com/r/input",
    "https://intentui.com/r/text",
    "https://intentui.com/r/text-field"
  ],
  "files": [
    {
      "path": "src/components/docs/forms/field/field-demo.tsx",
      "content": "\"use client\"\n\nimport { Form } from \"react-aria-components\"\nimport { Button } from \"@/components/ui/button\"\nimport { Description, FieldError, Fieldset, Label, Legend } from \"@/components/ui/field\"\nimport { Input } from \"@/components/ui/input\"\nimport { Text } from \"@/components/ui/text\"\nimport { TextField } from \"@/components/ui/text-field\"\n\nexport default function FieldDemo() {\n  return (\n    <Form>\n      <Fieldset>\n        <Legend>Profile information</Legend>\n        <Text>Update your account's profile information and email address.</Text>\n\n        <TextField isRequired name=\"name\">\n          <Label>Name</Label>\n          <Input />\n          <FieldError />\n          <Description>This is your public display name.</Description>\n        </TextField>\n        <TextField isRequired name=\"email\">\n          <Label>Email</Label>\n          <Description>This is your public display name.</Description>\n          <Input type=\"email\" />\n          <FieldError />\n        </TextField>\n        <TextField isRequired name=\"password\">\n          <Label>Password</Label>\n          <Input type=\"password\" />\n          <FieldError />\n        </TextField>\n        <div data-slot=\"control\">\n          <Button type=\"submit\">Register</Button>\n        </div>\n      </Fieldset>\n    </Form>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/field-demo/page.tsx"
    }
  ],
  "type": "registry:page"
}
