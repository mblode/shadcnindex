{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "extends": "none",
  "name": "popover-custom-close",
  "title": "Popover Custom Close",
  "description": "popover-custom-close",
  "dependencies": ["react-aria-components"],
  "registryDependencies": [
    "https://intentui.com/r/button",
    "https://intentui.com/r/checkbox",
    "https://intentui.com/r/dialog",
    "https://intentui.com/r/field",
    "https://intentui.com/r/input",
    "https://intentui.com/r/link",
    "https://intentui.com/r/popover",
    "https://intentui.com/r/text-field"
  ],
  "files": [
    {
      "path": "src/components/docs/overlays/popover/popover-custom-close.tsx",
      "content": "\"use client\"\n\nimport { Form } from \"react-aria-components\"\nimport { Button } from \"@/components/ui/button\"\nimport { Checkbox } from \"@/components/ui/checkbox\"\nimport { Dialog } from \"@/components/ui/dialog\"\nimport { FieldError, Label } from \"@/components/ui/field\"\nimport { Input } from \"@/components/ui/input\"\nimport { Link } from \"@/components/ui/link\"\nimport {\n  Popover,\n  PopoverBody,\n  PopoverClose,\n  PopoverContent,\n  PopoverDescription,\n  PopoverFooter,\n  PopoverHeader,\n  PopoverTitle,\n} from \"@/components/ui/popover\"\nimport { TextField } from \"@/components/ui/text-field\"\n\nexport default function PopoverCustomClose() {\n  return (\n    <Popover>\n      <Button>Login</Button>\n      <PopoverContent className=\"w-full min-w-96\">\n        <Dialog>\n          <PopoverHeader>\n            <PopoverTitle>Login</PopoverTitle>\n            <PopoverDescription>Enter your credentials to sign in.</PopoverDescription>\n          </PopoverHeader>\n          <Form onSubmit={() => {}} className=\"overflow-auto\">\n            <PopoverBody>\n              <div className=\"space-y-4\">\n                <TextField autoFocus isRequired>\n                  <Label>Email</Label>\n                  <Input type=\"email\" placeholder=\"Enter your email\" />\n                </TextField>\n                <TextField isRequired>\n                  <Label>Password</Label>\n                  <Input type=\"password\" placeholder=\"Enter your password\" />\n                  <FieldError />\n                </TextField>\n                <div className=\"flex items-center justify-between\">\n                  <Checkbox name=\"remember-me\">Remember me</Checkbox>\n                  <Link\n                    className=\"text-base/6 text-primary-subtle-fg hover:underline sm:text-sm/6\"\n                    href=\"#\"\n                  >\n                    Forgot password?\n                  </Link>\n                </div>\n              </div>\n            </PopoverBody>\n            <PopoverFooter>\n              <PopoverClose>Cancel</PopoverClose>\n              <Button type=\"submit\">Login</Button>\n            </PopoverFooter>\n          </Form>\n        </Dialog>\n      </PopoverContent>\n    </Popover>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/popover-custom-close/page.tsx"
    }
  ],
  "type": "registry:page"
}
