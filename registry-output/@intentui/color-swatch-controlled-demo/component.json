{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "extends": "none",
  "name": "color-swatch-controlled-demo",
  "title": "Color Swatch Controlled",
  "description": "color-swatch-controlled-demo",
  "dependencies": ["@react-stately/color"],
  "registryDependencies": [
    "https://intentui.com/r/color-swatch",
    "https://intentui.com/r/color-swatch-picker"
  ],
  "files": [
    {
      "path": "src/components/docs/colors/color-swatch/color-swatch-controlled-demo.tsx",
      "content": "\"use client\"\n\nimport { parseColor } from \"@react-stately/color\"\nimport { useState } from \"react\"\nimport { ControlledValues } from \"@/components/docs/colors/controlled-values\"\nimport { ColorSwatch } from \"@/components/ui/color-swatch\"\nimport { ColorSwatchPicker, ColorSwatchPickerItem } from \"@/components/ui/color-swatch-picker\"\n\nexport default function ColorSwatchPickerDemo() {\n  const [value, setValue] = useState(parseColor(\"#0d6efd\"))\n  return (\n    <div className=\"flex flex-col gap-4\">\n      <ColorSwatchPicker\n        aria-label=\"Pick color\"\n        value={value}\n        onChange={setValue}\n        className=\"flex justify-center gap-2\"\n      >\n        <ColorSwatchPickerItem color=\"#f59e0b\">\n          <ColorSwatch />\n        </ColorSwatchPickerItem>\n        <ColorSwatchPickerItem color=\"#84cc16\">\n          <ColorSwatch />\n        </ColorSwatchPickerItem>\n        <ColorSwatchPickerItem color=\"#0d6efd\">\n          <ColorSwatch />\n        </ColorSwatchPickerItem>\n        <ColorSwatchPickerItem color=\"#ec4899\">\n          <ColorSwatch />\n        </ColorSwatchPickerItem>\n        <ColorSwatchPickerItem color=\"#f43f5e\">\n          <ColorSwatch />\n        </ColorSwatchPickerItem>\n      </ColorSwatchPicker>\n      <ControlledValues color={value} />\n    </div>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/color-swatch-controlled-demo/page.tsx"
    }
  ],
  "type": "registry:page"
}
