{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "extends": "none",
  "name": "color-area-with-slider-demo",
  "title": "Color Area With Slider",
  "description": "color-area-with-slider-demo",
  "dependencies": ["@react-stately/color"],
  "registryDependencies": [
    "https://intentui.com/r/color-area",
    "https://intentui.com/r/color-field",
    "https://intentui.com/r/color-slider",
    "https://intentui.com/r/field",
    "https://intentui.com/r/input",
    "https://intentui.com/r/slider"
  ],
  "files": [
    {
      "path": "src/components/docs/colors/color-area/color-area-with-slider-demo.tsx",
      "content": "\"use client\"\n\nimport { parseColor } from \"@react-stately/color\"\nimport { useState } from \"react\"\n\nimport { ColorArea } from \"@/components/ui/color-area\"\nimport { ColorField } from \"@/components/ui/color-field\"\nimport { ColorSlider } from \"@/components/ui/color-slider\"\nimport { Label } from \"@/components/ui/field\"\nimport { Input } from \"@/components/ui/input\"\nimport { SliderOutput } from \"@/components/ui/slider\"\n\nexport default function ColorAreaWithSliderDemo() {\n  const [color, setColor] = useState(parseColor(\"hsl(50, 100%, 50%)\"))\n  return (\n    <div className=\"flex min-w-56 flex-col gap-y-2\">\n      <ColorArea\n        className=\"w-full shrink-0\"\n        value={color}\n        onChange={setColor}\n        xChannel=\"saturation\"\n        yChannel=\"lightness\"\n      />\n      <ColorSlider\n        className=\"orientation-horizontal:w-full\"\n        channel=\"hue\"\n        value={color}\n        onChange={setColor}\n      >\n        <Label>Fill color</Label>\n        <SliderOutput />\n      </ColorSlider>\n\n      <ColorField value={color.toString(\"hex\")}>\n        <Label>CurrentColor</Label>\n        <Input />\n      </ColorField>\n    </div>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/color-area-with-slider-demo/page.tsx"
    }
  ],
  "type": "registry:page"
}
