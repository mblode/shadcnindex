{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "extends": "none",
  "name": "tooltip-without-arrow-demo",
  "title": "Tooltip Without Arrow",
  "description": "tooltip-without-arrow-demo",
  "registryDependencies": [
    "https://intentui.com/r/badge",
    "https://intentui.com/r/field",
    "https://intentui.com/r/tooltip"
  ],
  "files": [
    {
      "path": "src/components/docs/overlays/tooltip/tooltip-without-arrow-demo.tsx",
      "content": "\"use client\"\n\nimport { Badge } from \"@/components/ui/badge\"\nimport { Description } from \"@/components/ui/field\"\nimport { Tooltip, TooltipContent, TooltipTrigger } from \"@/components/ui/tooltip\"\n\nexport default function TooltipWithoutArrowDemo() {\n  return (\n    <Tooltip>\n      <TooltipTrigger aria-label=\"Fresh drop alert\">\n        <Badge isCircle>New</Badge>\n      </TooltipTrigger>\n      <TooltipContent arrow={false}>\n        <strong className=\"font-semibold\">Fresh drop alert</strong> <br />\n        <Description>Scope the newest addition to our stash.</Description>\n      </TooltipContent>\n    </Tooltip>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/tooltip-without-arrow-demo/page.tsx"
    }
  ],
  "type": "registry:page"
}
