      "content": "\"use client\"\n\nimport { useState } from \"react\"\n\nimport { Description } from \"@/components/ui/field\"\nimport { SearchField, SearchInput } from \"@/components/ui/search-field\"\n\nexport default function SearchFieldControlledDemo() {\n  const [value, setValue] = useState(\"\")\n  return (\n    <>\n      <SearchField value={value} onChange={setValue} className=\"mb-2\" aria-label=\"Search\">\n        <SearchInput />\n      </SearchField>\n      <Description className=\"mt-2 block [&>strong]:text-fg\">\n        You have typed: <strong>{value ?? \"-\"}</strong>\n      </Description>\n    </>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/search-field-controlled-demo/page.tsx"
    }
  ],
  "type": "registry:page"
