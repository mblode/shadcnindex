      "path": "src/components/docs/forms/text-field/text-field-prefix-suffix-demo.tsx",
      "content": "\"use client\"\n\nimport { AtSymbolIcon } from \"@heroicons/react/24/outline\"\nimport { BrandXIcon } from \"@/components/icons/brand-x-icon\"\nimport { Label } from \"@/components/ui/field\"\nimport { Input, InputGroup } from \"@/components/ui/input\"\nimport { Text } from \"@/components/ui/text\"\nimport { TextField } from \"@/components/ui/text-field\"\nexport default function TextFieldPrefixSuffixDemo() {\n  return (\n    <div className=\"flex flex-col gap-4\">\n      <TextField>\n        <Label>Twitter</Label>\n        <InputGroup>\n          <AtSymbolIcon />\n          <Input placeholder=\"irsyadadl\" />\n          <BrandXIcon />\n        </InputGroup>\n      </TextField>\n      <TextField>\n        <Label>Sites</Label>\n        <InputGroup className=\"[--input-gutter-end:--spacing(12)] [--input-gutter-start:--spacing(16)]\">\n          <Text>https://</Text>\n          <Input />\n          <Text>.com</Text>\n        </InputGroup>\n      </TextField>\n    </div>\n  )\n}\n",
      "type": "registry:page",
      "target": "app/text-field-prefix-suffix-demo/page.tsx"
    }
  ],
  "type": "registry:page"
