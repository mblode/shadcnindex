{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dialog-demo",
  "type": "registry:example",
  "registryDependencies": ["dialog"],
  "files": [
    {
      "path": "src/registry/pure-ui/examples/dialog/dialog-demo.tsx",
      "content": "import {\n  Dialog,\n  DialogPopup,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n  DialogClose,\n} from \"@/registry/pure-ui/ui/dialog\";\n\nimport { Button } from \"@/registry/pure-ui/ui/button\";\nimport { Input } from \"@/registry/pure-ui/ui/input\";\nimport { Label } from \"@/registry/pure-ui/ui/label\";\n\nexport const DialogDemo = () => {\n  return (\n    <Dialog>\n      <DialogTrigger render={<Button variant=\"outline\" />}>\n        Edit profile\n      </DialogTrigger>\n      <DialogPopup className=\"sm:max-w-sm\">\n        <DialogHeader>\n          <DialogTitle>Edit profile</DialogTitle>\n          <DialogDescription>\n            Make changes to your profile here. Click save when you&apos;re done.\n          </DialogDescription>\n        </DialogHeader>\n        <div className=\"flex flex-col gap-4\">\n          <div className=\"\">\n            <Label>Name</Label>\n            <Input type=\"text\" defaultValue=\"Krishna\" />\n          </div>\n          <div className=\"\">\n            <Label>Username</Label>\n            <Input type=\"text\" defaultValue=\"@krishna\" />\n          </div>\n        </div>\n        <DialogFooter>\n          <DialogClose render={<Button variant=\"ghost\" />}>Cancel</DialogClose>\n          <Button type=\"submit\">Save</Button>\n        </DialogFooter>\n      </DialogPopup>\n    </Dialog>\n  );\n};\n",
      "type": "registry:example"
    }
  ]
}
