{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dj-skazi-profile",
  "type": "registry:component",
  "title": "DJ Profile A modern digital profile card component",
  "description": "A stylish and responsive profile component for showcasing a user’s digital presence.",
  "dependencies": ["zod", "lucide-react", "clsx"],
  "devDependencies": [
    "typescript",
    "eslint",
    "prettier",
    "tailwindcss",
    "@types/react",
    "@types/node"
  ],
  "registryDependencies": ["button", "input"],
  "files": [
    {
      "id": 40,
      "path": "digi-scazi-profile.tsx",
      "content": "\"use client\"\n\nimport { useState } from \"react\"\nimport Image from \"next/image\"\nimport { motion, AnimatePresence } from \"framer-motion\"\nimport { Instagram, AirplayIcon as Spotify, Youtube, Music, Calendar, Play, Pause, X } from \"lucide-react\"\nimport { Button } from \"@/components/ui/button\"\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from \"@/components/ui/tabs\"\nimport { Dialog, DialogContent } from \"@/components/ui/dialog\"\nimport { Avatar, AvatarFallback, AvatarImage } from \"@/components/ui/avatar\"\n\nexport default function DigiScaziProfile() {\n  const [isPlaying, setIsPlaying] = useState(false)\n  const [activeTab, setActiveTab] = useState(\"about\")\n  const [showModal, setShowModal] = useState(false)\n\n  const togglePlay = () => {\n    setIsPlaying(!isPlaying)\n  }\n\n  const upcomingShows = [\n    {\n      date: \"May 15, 2024\",\n      venue: \"The Block, Tel Aviv\",\n      ticketLink: \"#\",\n    },\n    {\n      date: \"May 22, 2024\",\n      venue: \"Alphabet, Berlin\",\n      ticketLink: \"#\",\n    },\n    {\n      date: \"May 30, 2024\",\n      venue: \"Fabric, London\",\n      ticketLink: \"#\",\n    },\n  ]\n\n  const releases = [\n    {\n      title: \"Midnight Dreams\",\n      label: \"Anjunadeep\",\n      year: \"2023\",\n      image: \"/placeholder.svg?height=300&width=300\",\n      link: \"#\",\n    },\n    {\n      title: \"Desert Mirage\",\n      label: \"Diynamic\",\n      year: \"2022\",\n      image: \"/placeholder.svg?height=300&width=300\",\n      link: \"#\",\n    },\n    {\n      title: \"Urban Echoes EP\",\n      label: \"Innervisions\",\n      year: \"2021\",\n      image: \"/placeholder.svg?height=300&width=300\",\n      link: \"#\",\n    },\n  ]\n\n  return (\n    <div className=\"relative min-h-screen bg-black text-white overflow-hidden\">\n      {/* Team Section */}\n      <div className=\"container mx-auto py-24 px-4\">\n        <div className=\"text-center mb-16\">\n          <h2 className=\"text-4xl font-bold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-500\">\n            Our Team\n          </h2>\n          <p className=\"text-lg text-gray-300 max-w-2xl mx-auto\">\n            Meet the talented individuals behind the music, creating unforgettable experiences for audiences worldwide.\n          </p>\n        </div>\n\n        <div className=\"flex flex-wrap justify-center gap-16\">\n          {/* Digi Scazi Profile */}\n          <motion.div\n            className=\"group relative cursor-pointer transition-all duration-300\"\n            onClick={() => setShowModal(true)}\n            whileHover={{ scale: 1.05 }}\n          >\n            <div className=\"flex flex-col items-center\">\n              <div className=\"relative mb-4 transform transition-transform duration-300\">\n                <div className=\"absolute -inset-1 rounded-full bg-gradient-to-r from-pink-500 to-purple-500 opacity-75 blur group-hover:opacity-100 transition-opacity duration-300\"></div>\n                <Avatar className=\"w-64 h-64 border-2 border-white\">\n                  <AvatarImage\n                    src=\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/image-dW4qmCb4IGtjbVPd6PPDSBn7qFG23s.png\"\n                    alt=\"Digi Scazi\"\n                  />\n                  <AvatarFallback className=\"text-3xl\">DS</AvatarFallback>\n                </Avatar>\n                <div className=\"absolute -bottom-2 left-1/2 transform -translate-x-1/2 bg-white text-black px-4 py-1 rounded-full shadow-md opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap\">\n                  Click for details\n                </div>\n              </div>\n              <h3 className=\"text-2xl font-bold text-center\">Digi Scazi</h3>\n              <p className=\"text-gray-300 text-center\">DJ / Producer</p>\n            </div>\n          </motion.div>\n\n          {/* You can add more team members here */}\n        </div>\n      </div>\n\n      {/* Modal with all information */}\n      <Dialog open={showModal} onOpenChange={setShowModal}>\n        <DialogContent\n          className=\"max-w-6xl p-0 bg-black border border-zinc-800 rounded-xl overflow-hidden\"\n          onInteractOutside={(e) => e.preventDefault()}\n        >\n          <div className=\"relative h-screen overflow-y-auto scrollbar-hide\">\n            {/* Close button */}\n            <Button\n              variant=\"ghost\"\n              size=\"icon\"\n              onClick={() => setShowModal(false)}\n              className=\"absolute top-4 right-4 z-50 bg-black/50 backdrop-blur-sm rounded-full hover:bg-black/70\"\n            >\n              <X className=\"h-5 w-5\" />\n              <span className=\"sr-only\">Close</span>\n            </Button>\n\n            {/* Hero Section */}\n            <div className=\"relative h-[50vh] flex items-center justify-center overflow-hidden\">\n              {/* Background gradient overlay */}\n              <div className=\"absolute inset-0 bg-gradient-to-b from-pink-900/30 to-black z-10\"></div>\n\n              {/* Background image */}\n              <div className=\"absolute inset-0 z-0\">\n                <Image\n                  src=\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/image-dW4qmCb4IGtjbVPd6PPDSBn7qFG23s.png\"\n                  alt=\"Digi Scazi\"\n                  fill\n                  className=\"object-cover object-center\"\n                  priority\n                />\n              </div>\n\n              {/* Floating particles effect */}\n              <div className=\"absolute inset-0 z-0\">\n                {Array.from({ length: 20 }).map((_, i) => (\n                  <motion.div\n                    key={i}\n                    className=\"absolute w-2 h-2 bg-white rounded-full opacity-30\"\n                    animate={{\n                      x: [Math.random() * 100 - 50, Math.random() * 100 - 50, Math.random() * 100 - 50],\n                      y: [Math.random() * 100 - 50, Math.random() * 100 - 50, Math.random() * 100 - 50],\n                    }}\n                    transition={{\n                      duration: 10 + Math.random() * 20,\n                      repeat: Number.POSITIVE_INFINITY,\n                      repeatType: \"reverse\",\n                    }}\n                    style={{\n                      left: `${Math.random() * 100}%`,\n                      top: `${Math.random() * 100}%`,\n                    }}\n                  />\n                ))}\n              </div>\n\n              {/* Hero content */}\n              <motion.div\n                className=\"relative z-20 text-center px-4\"\n                initial={{ opacity: 0, y: 50 }}\n                animate={{ opacity: 1, y: 0 }}\n                transition={{ delay: 0.2, duration: 0.8 }}\n              >\n                <motion.h1\n                  className=\"text-6xl md:text-8xl font-bold mb-4 text-white drop-shadow-lg\"\n                  initial={{ scale: 0.8 }}\n                  animate={{ scale: 1 }}\n                  transition={{\n                    type: \"spring\",\n                    stiffness: 100,\n                    delay: 0.4,\n                  }}\n                >\n                  Digi Scazi\n                </motion.h1>\n\n                <motion.div\n                  className=\"flex flex-wrap justify-center gap-3 mb-8\"\n                  initial={{ opacity: 0 }}\n                  animate={{ opacity: 1 }}\n                  transition={{ delay: 0.6 }}\n                >\n                  <span className=\"px-4 py-1 bg-pink-500/30 backdrop-blur-sm rounded-full text-sm\">DJ</span>\n                  <span className=\"px-4 py-1 bg-purple-500/30 backdrop-blur-sm rounded-full text-sm\">Producer</span>\n                  <span className=\"px-4 py-1 bg-blue-500/30 backdrop-blur-sm rounded-full text-sm\">\n                    Electronic Artist\n                  </span>\n                </motion.div>\n\n                <motion.div\n                  className=\"flex justify-center gap-4 mb-12\"\n                  initial={{ opacity: 0, y: 20 }}\n                  animate={{ opacity: 1, y: 0 }}\n                  transition={{ delay: 0.8 }}\n                >\n                  <a href=\"#\" className=\"text-white hover:text-pink-400 transition-colors\">\n                    <Instagram size={24} />\n                  </a>\n                  <a href=\"#\" className=\"text-white hover:text-green-400 transition-colors\">\n                    <Spotify size={24} />\n                  </a>\n                  <a href=\"#\" className=\"text-white hover:text-red-400 transition-colors\">\n                    <Youtube size={24} />\n                  </a>\n                </motion.div>\n\n                <motion.div\n                  initial={{ scale: 0.8, opacity: 0 }}\n                  animate={{ scale: 1, opacity: 1 }}\n                  transition={{ delay: 1 }}\n                >\n                  <Button\n                    onClick={togglePlay}\n                    size=\"lg\"\n                    className=\"bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-700 hover:to-purple-700 rounded-full px-8\"\n                  >\n                    {isPlaying ? (\n                      <>\n                        <Pause className=\"mr-2\" size={18} /> Stop Playing\n                      </>\n                    ) : (\n                      <>\n                        <Play className=\"mr-2\" size={18} /> Play Track\n                      </>\n                    )}\n                  </Button>\n                </motion.div>\n              </motion.div>\n            </div>\n\n            {/* Content Section */}\n            <div className=\"relative z-20 bg-black py-16 px-4 md:px-8\">\n              <div className=\"max-w-6xl mx-auto\">\n                <Tabs defaultValue=\"about\" value={activeTab} onValueChange={setActiveTab} className=\"w-full\">\n                  <div className=\"flex justify-center mb-12\">\n                    <TabsList className=\"bg-zinc-900/50 backdrop-blur-md p-1 rounded-full\">\n                      <TabsTrigger\n                        value=\"about\"\n                        className=\"data-[state=active]:bg-gradient-to-r data-[state=active]:from-pink-600 data-[state=active]:to-purple-600 rounded-full px-6 py-2\"\n                      >\n                        About\n                      </TabsTrigger>\n                      <TabsTrigger\n                        value=\"shows\"\n                        className=\"data-[state=active]:bg-gradient-to-r data-[state=active]:from-pink-600 data-[state=active]:to-purple-600 rounded-full px-6 py-2\"\n                      >\n                        Shows\n                      </TabsTrigger>\n                      <TabsTrigger\n                        value=\"music\"\n                        className=\"data-[state=active]:bg-gradient-to-r data-[state=active]:from-pink-600 data-[state=active]:to-purple-600 rounded-full px-6 py-2\"\n                      >\n                        Music\n                      </TabsTrigger>\n                    </TabsList>\n                  </div>\n\n                  <AnimatePresence mode=\"wait\">\n                    <TabsContent value=\"about\" className=\"mt-0\" key=\"about\">\n                      <motion.div\n                        initial={{ opacity: 0, y: 20 }}\n                        animate={{ opacity: 1, y: 0 }}\n                        exit={{ opacity: 0, y: -20 }}\n                        transition={{ duration: 0.5 }}\n                        className=\"grid md:grid-cols-2 gap-12 items-center\"\n                      >\n                        <div>\n                          <h2 className=\"text-3xl font-bold mb-6 text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-500\">\n                            My Story\n                          </h2>\n                          <div className=\"space-y-4 text-lg text-gray-300\">\n                            <p>\n                              Digi Scazi is one of the leading names in the Israeli and international electronic music\n                              scene. With a unique style that combines techno, house, and ethnic melodies, Scazi has\n                              established himself as an innovative and groundbreaking artist.\n                            </p>\n                            <p>\n                              After starting his journey in Tel Aviv clubs, his name quickly spread around the world,\n                              and he began performing at leading festivals and clubs in Europe, America, and Asia. His\n                              unique sound, combining electronic beats with Middle Eastern influences, has become a\n                              recognizable musical signature.\n                            </p>\n                            <p>\n                              Today, Scazi runs his own label, produces original music, and collaborates with leading\n                              artists from around the world. His sets are known for their relentless energy and ability\n                              to connect different audiences and musical styles.\n                            </p>\n                          </div>\n                        </div>\n\n                        <div className=\"relative\">\n                          <motion.div\n                            className=\"absolute -inset-4 rounded-xl bg-gradient-to-r from-pink-500 to-purple-500 opacity-30 blur-xl\"\n                            animate={{\n                              scale: [1, 1.05, 1],\n                              opacity: [0.2, 0.3, 0.2],\n                            }}\n                            transition={{\n                              duration: 4,\n                              repeat: Number.POSITIVE_INFINITY,\n                              repeatType: \"reverse\",\n                            }}\n                          />\n                          <div className=\"relative aspect-square overflow-hidden rounded-xl\">\n                            <Image\n                              src=\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/image-dW4qmCb4IGtjbVPd6PPDSBn7qFG23s.png\"\n                              alt=\"Digi Scazi\"\n                              fill\n                              className=\"object-cover object-center\"\n                            />\n                          </div>\n                        </div>\n                      </motion.div>\n                    </TabsContent>\n\n                    <TabsContent value=\"shows\" className=\"mt-0\" key=\"shows\">\n                      <motion.div\n                        initial={{ opacity: 0, y: 20 }}\n                        animate={{ opacity: 1, y: 0 }}\n                        exit={{ opacity: 0, y: -20 }}\n                        transition={{ duration: 0.5 }}\n                      >\n                        <h2 className=\"text-3xl font-bold mb-10 text-center text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-500\">\n                          Upcoming Shows\n                        </h2>\n\n                        <div className=\"grid gap-6\">\n                          {upcomingShows.map((show, index) => (\n                            <motion.div\n                              key={index}\n                              initial={{ opacity: 0, y: 20 }}\n                              animate={{ opacity: 1, y: 0 }}\n                              transition={{ delay: index * 0.1 }}\n                              className=\"bg-zinc-900/50 backdrop-blur-sm rounded-xl p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4 hover:bg-zinc-800/50 transition-colors\"\n                            >\n                              <div className=\"flex items-center gap-6\">\n                                <div className=\"flex-shrink-0 w-16 h-16 rounded-full bg-gradient-to-r from-pink-600 to-purple-600 flex items-center justify-center\">\n                                  <Calendar size={24} />\n                                </div>\n                                <div>\n                                  <h3 className=\"text-xl font-bold\">{show.venue}</h3>\n                                  <p className=\"text-gray-400\">{show.date}</p>\n                                </div>\n                              </div>\n                              <Button\n                                asChild\n                                className=\"bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-700 hover:to-purple-700 rounded-full px-8\"\n                              >\n                                <a href={show.ticketLink}>Tickets</a>\n                              </Button>\n                            </motion.div>\n                          ))}\n                        </div>\n                      </motion.div>\n                    </TabsContent>\n\n                    <TabsContent value=\"music\" className=\"mt-0\" key=\"music\">\n                      <motion.div\n                        initial={{ opacity: 0, y: 20 }}\n                        animate={{ opacity: 1, y: 0 }}\n                        exit={{ opacity: 0, y: -20 }}\n                        transition={{ duration: 0.5 }}\n                      >\n                        <h2 className=\"text-3xl font-bold mb-10 text-center text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-500\">\n                          Latest Releases\n                        </h2>\n\n                        <div className=\"grid md:grid-cols-3 gap-8\">\n                          {releases.map((release, index) => (\n                            <motion.a\n                              href={release.link}\n                              key={index}\n                              initial={{ opacity: 0, y: 20 }}\n                              animate={{ opacity: 1, y: 0 }}\n                              transition={{ delay: index * 0.1 }}\n                              className=\"group relative overflow-hidden rounded-xl\"\n                              whileHover={{ scale: 1.03 }}\n                              whileTap={{ scale: 0.98 }}\n                            >\n                              <div className=\"aspect-square relative overflow-hidden\">\n                                <Image\n                                  src={release.image || \"/placeholder.svg\"}\n                                  alt={release.title}\n                                  fill\n                                  className=\"object-cover transition-transform duration-500 group-hover:scale-110\"\n                                />\n                                <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6\">\n                                  <div>\n                                    <h3 className=\"text-xl font-bold\">{release.title}</h3>\n                                    <p className=\"text-gray-300\">\n                                      {release.label} | {release.year}\n                                    </p>\n                                  </div>\n                                </div>\n                                <div className=\"absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300\">\n                                  <div className=\"w-16 h-16 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center\">\n                                    <Play size={24} className=\"text-white\" />\n                                  </div>\n                                </div>\n                              </div>\n                            </motion.a>\n                          ))}\n                        </div>\n\n                        <div className=\"mt-12 text-center\">\n                          <Button\n                            asChild\n                            variant=\"outline\"\n                            className=\"rounded-full border-pink-500 text-pink-500 hover:bg-pink-500/10\"\n                          >\n                            <a href=\"#\">\n                              <Music className=\"mr-2\" size={18} />\n                              View All Music\n                            </a>\n                          </Button>\n                        </div>\n                      </motion.div>\n                    </TabsContent>\n                  </AnimatePresence>\n                </Tabs>\n              </div>\n            </div>\n\n            {/* Contact Section */}\n            <motion.div\n              className=\"relative z-20 py-16 px-4 md:px-8 bg-gradient-to-b from-black to-zinc-900\"\n              initial={{ opacity: 0 }}\n              whileInView={{ opacity: 1 }}\n              viewport={{ once: true }}\n              transition={{ duration: 0.8 }}\n            >\n              <div className=\"max-w-4xl mx-auto text-center\">\n                <h2 className=\"text-3xl md:text-4xl font-bold mb-6 text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-purple-500\">\n                  Let's Work Together\n                </h2>\n                <p className=\"text-xl text-gray-300 mb-10\">\n                  Interested in booking a show, musical collaboration, or any other inquiry?\n                </p>\n                <Button\n                  asChild\n                  size=\"lg\"\n                  className=\"bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-700 hover:to-purple-700 rounded-full px-10 py-6 text-lg\"\n                >\n                  <a href=\"mailto:contact@digiscazi.com\">Get In Touch</a>\n                </Button>\n              </div>\n            </motion.div>\n          </div>\n        </DialogContent>\n      </Dialog>\n    </div>\n  )\n}",
      "type": "registry:component"
    }
  ],
  "categories": ["Animation", "Template"]
}
