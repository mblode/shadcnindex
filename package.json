{
  "name": "shadcnindex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "crawl-registries": "tsx scripts/crawl-registries.ts",
    "update-registries": "tsx scripts/update-registries.ts",
    "build-local-index": "tsx scripts/build-local-index.ts",
    "registry:embed": "tsx scripts/index-registry-embeddings.ts",
    "registry:sync": "npm run update-registries && npm run crawl-registries && npm run build-local-index && npm run registry:embed",
    "prepare": "husky",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "tsx": "^4.21.0",
    "turbo": "^2.7.2",
    "ultracite": "^7.0.5"
  },
  "packageManager": "npm@11.7.0",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "npx ultracite fix"
    ]
  }
}
